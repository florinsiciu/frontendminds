# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Resend (email)
RESEND_API_KEY=re_your-api-key
RESEND_AUDIENCE_ID=your-audience-id

# PostHog (analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_your-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Site — set to your production domain before deploying
NEXT_PUBLIC_SITE_URL=https://frontendminds.com

# Cron job authentication — generate with: openssl rand -hex 32
CRON_SECRET=

ADMIN_SECRET=any-secret-you-choose